pipeline {
    agent any

    parameters {
        choice(name: 'TERRAFORM_ENV', choices: ['stage', 'prod'], description: 'Target environment to deploy')
        choice(name: 'TOOLS_ENV', choices: ['stage'], description: 'Environment where shared Jenkins/Nexus/SonarQube live')
        string(name: 'AWS_REGION', defaultValue: 'us-east-1', description: 'AWS region used by Terraform and discovery script')
        booleanParam(name: 'ENABLE_NEW_RELIC', defaultValue: false, description: 'Install New Relic infrastructure agent on app nodes after deploy')
    }

    environment {
        APP_NAME      = 'pet-adoption'
        APP_VERSION   = "${env.BUILD_NUMBER}"
        SONARQUBE_ENV = 'sonarqube'
        DOCKER_IMAGE  = 'pet-adoption'
    }

    tools {
        jdk 'jdk21'
        maven 'maven3'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Prepare Workspace') {
            steps { sh 'mkdir -p reports' }
        }

        stage('Read Terraform Outputs') {
            steps {
                script {
                    sh """
                        cd ${WORKSPACE}
                        chmod +x scripts/init-env.sh
                        ./scripts/init-env.sh ${params.TERRAFORM_ENV}
                        ./scripts/init-env.sh ${params.TOOLS_ENV}
                    """

                    dir("environment/${params.TERRAFORM_ENV}") {
                        sh '/usr/local/bin/terraform init -reconfigure -backend-config=backend.auto.hcl'

                        env.ASG_NAME = sh(script: '/usr/local/bin/terraform output -raw asg_name', returnStdout: true).trim()
                        env.BASTION_PUBLIC_IP = sh(script: '/usr/local/bin/terraform output -raw bastion_public_ip', returnStdout: true).trim()
                        env.BASTION_PRIVATE_IP = sh(script: '/usr/local/bin/terraform output -raw bastion_private_ip', returnStdout: true).trim()
                        env.APPLICATION_URL = sh(script: '/usr/local/bin/terraform output -raw application_url', returnStdout: true).trim()
                    }

                    dir("environment/${params.TOOLS_ENV}") {
                        sh '/usr/local/bin/terraform init -reconfigure -backend-config=backend.auto.hcl'

                        env.NEXUS_URL = sh(script: '/usr/local/bin/terraform output -raw nexus_url', returnStdout: true).trim()
                        env.NEXUS_REGISTRY = sh(script: '/usr/local/bin/terraform output -raw nexus_docker_registry', returnStdout: true).trim()
                    }

                    if (params.TERRAFORM_ENV == params.TOOLS_ENV) {
                        env.BASTION_JUMP_IP = env.BASTION_PRIVATE_IP
                    } else {
                        env.BASTION_JUMP_IP = env.BASTION_PUBLIC_IP
                    }

                    echo "Target env: ${params.TERRAFORM_ENV}"
                    echo "Tools env: ${params.TOOLS_ENV}"
                    echo "ASG: ${env.ASG_NAME}"
                    echo "Bastion jump IP: ${env.BASTION_JUMP_IP}"
                    echo "Nexus URL: ${env.NEXUS_URL}"
                    echo "Nexus Registry: ${env.NEXUS_REGISTRY}"
                    echo "Application URL: ${env.APPLICATION_URL}"
                }
            }
        }

        stage('Build WAR') {
            steps {
                dir('app') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                dir('app') {
                    sh 'trivy fs --severity HIGH,CRITICAL --no-progress . || true'
                }
            }
        }

        stage('SonarQube Scan') {
            steps {
                dir('app') {
                    withSonarQubeEnv("${SONARQUBE_ENV}") {
                        sh '''
                            mvn sonar:sonar \
                              -Dsonar.projectKey=pet-adoption \
                              -Dsonar.projectName=pet-adoption \
                              -Dsonar.login=$SONAR_AUTH_TOKEN
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Upload WAR to Nexus') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'nexus-creds', usernameVariable: 'NEXUS_USER', passwordVariable: 'NEXUS_PASS')]) {
                    sh '''
                        curl -v -u "$NEXUS_USER:$NEXUS_PASS" \
                          --upload-file app/target/pet-adoption.war \
                          "${NEXUS_URL}/repository/raw-hosted/pet-adoption/${APP_VERSION}/pet-adoption.war"
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t ${DOCKER_IMAGE}:${APP_VERSION} app'
                sh 'docker tag ${DOCKER_IMAGE}:${APP_VERSION} ${NEXUS_REGISTRY}/${DOCKER_IMAGE}:${APP_VERSION}'
                sh 'docker tag ${DOCKER_IMAGE}:${APP_VERSION} ${NEXUS_REGISTRY}/${DOCKER_IMAGE}:latest'
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh 'trivy image --severity HIGH,CRITICAL --no-progress ${DOCKER_IMAGE}:${APP_VERSION} || true'
            }
        }

        stage('Push Docker Image to Nexus') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'nexus-creds', usernameVariable: 'NEXUS_USER', passwordVariable: 'NEXUS_PASS')]) {
                    sh '''
                        echo "$NEXUS_PASS" | docker login ${NEXUS_REGISTRY} -u "$NEXUS_USER" --password-stdin
                        docker push ${NEXUS_REGISTRY}/${DOCKER_IMAGE}:${APP_VERSION}
                        docker push ${NEXUS_REGISTRY}/${DOCKER_IMAGE}:latest
                    '''
                }
            }
        }

        stage('Generate Dynamic Inventory') {
            steps {
                sh 'bash scripts/dynamic_inventory.sh ${AWS_REGION} ${ASG_NAME}'
                sh 'cat ansible/inventory.ini'
            }
        }

        stage('Bootstrap Docker on App Nodes') {
            steps {
                sh '''
                    export ANSIBLE_HOST_KEY_CHECKING=False
                    ansible-playbook -i ansible/inventory.ini \
                      --private-key /var/lib/jenkins/.ssh/my_key.pem \
                      -u ec2-user \
                      --ssh-common-args="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ProxyCommand='ssh -i /var/lib/jenkins/.ssh/my_key.pem -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -W %h:%p ec2-user@${BASTION_JUMP_IP}'" \
                      ansible/docker.yml
                '''
            }
        }

        stage('Deploy to Private App Nodes') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'nexus-creds', usernameVariable: 'NEXUS_USER', passwordVariable: 'NEXUS_PASS')]) {
                    script {
                        def nrKey = ''
                        if (params.ENABLE_NEW_RELIC) {
                            withCredentials([string(credentialsId: 'newrelic-license-key', variable: 'NEW_RELIC_LICENSE_KEY')]) {
                                nrKey = NEW_RELIC_LICENSE_KEY
                            }
                        }

                        sh """
                            export ANSIBLE_HOST_KEY_CHECKING=False
                            ansible-playbook -i ansible/inventory.ini \
                              --private-key /var/lib/jenkins/.ssh/my_key.pem \
                              -u ec2-user \
                              --ssh-common-args="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ProxyCommand='ssh -i /var/lib/jenkins/.ssh/my_key.pem -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -W %h:%p ec2-user@${BASTION_JUMP_IP}'" \
                              ansible/deploy.yml \
                              --extra-vars "nexus_registry=${NEXUS_REGISTRY} nexus_username=${NEXUS_USER} nexus_password=${NEXUS_PASS} image_name=${DOCKER_IMAGE} image_tag=${APP_VERSION} newrelic_license_key='${nrKey}' newrelic_app_name=${APP_NAME}-${params.TERRAFORM_ENV}"
                        """
                    }
                }
            }
        }

        stage('Install New Relic Infra Agent (Optional)') {
            when {
                expression { return params.ENABLE_NEW_RELIC }
            }
            steps {
                withCredentials([string(credentialsId: 'newrelic-license-key', variable: 'NEW_RELIC_LICENSE_KEY')]) {
                    sh """
                        export ANSIBLE_HOST_KEY_CHECKING=False
                        ansible-playbook -i ansible/inventory.ini \
                          --private-key /var/lib/jenkins/.ssh/my_key.pem \
                          -u ec2-user \
                          --ssh-common-args="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ProxyCommand='ssh -i /var/lib/jenkins/.ssh/my_key.pem -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -W %h:%p ec2-user@${BASTION_JUMP_IP}'" \
                          ansible/newrelic.yml \
                          --extra-vars "newrelic_license_key=${NEW_RELIC_LICENSE_KEY}"
                    """
                }
            }
        }

        stage('Smoke Test') {
            steps {
                sh 'curl -k --fail --silent --show-error ${APPLICATION_URL}/pet-adoption/ > /dev/null'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
        always {
            archiveArtifacts artifacts: 'app/target/*.war, ansible/inventory.ini', allowEmptyArchive: true
        }
    }
}